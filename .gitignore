# ==========================================
# TradeTerminal — Monorepo .gitignore
# ==========================================

# --- OS & Editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key

# --- Python (Backend) ---
backend/venv/
backend/.venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/.pytest_cache/
backend/.mypy_cache/
backend/*.egg-info/
backend/dist/
backend/build/

# --- Node (Frontend) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.cache/
frontend/.turbo/
frontend/coverage/
frontend/*.log

# --- Build & Dist (Root) ---
dist/
build/
*.tar.gz

# --- Markdown (sadece README.md commitli) ---
*.md
!README.md

# --- Misc ---
*.bak
*.tmp
.cache/
